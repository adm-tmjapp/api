{
  "compilerOptions": {
    "target": "ES6",                          // Versão do ECMAScript (pode ser ES5, ES6, etc).
    "module": "commonjs",                     // Módulo utilizado (CommonJS é padrão para Node.js).
    "outDir": "./dist",                       // Diretório onde os arquivos compilados serão gerados.
    "rootDir": "./src",                       // Diretório onde os arquivos .ts estão localizados.
    "strict": true,                           // Habilita verificação rigorosa de tipos.
    "skipLibCheck": true,                     // Ignora a verificação das bibliotecas de declaração.
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,  // Garante a consistência de maiúsculas/minúsculas no nome dos arquivos.
    "typeRoots": ["./src/@type", "./node_modules/@types"]
  },
  "include": [
    "src/**/*.ts",                            // Incluir todos os arquivos TypeScript no diretório src.
    "src/**/*.d.ts"                           // Incluir definições de tipos globais (ex.: Express Request.user).
  ],
  "exclude": [
    "node_modules"                            // Excluir o diretório node_modules da compilação.
  ]
}
